{
  "name": "City",
  "type": "object",
  "properties": {
    "trip_id": {
      "type": "string",
      "description": "ID del viaje"
    },
    "name": {
      "type": "string",
      "description": "City name"
    },
    "country": {
      "type": "string",
      "default": "Japan"
    },
    "image_url": {
      "type": "string",
      "description": "Cover image URL"
    },
    "order": {
      "type": "number",
      "description": "Order in itinerary"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Start date of stay"
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "description": "End date of stay"
    },
    "accommodation": {
      "type": "string",
      "description": "Nombre del alojamiento (hotel, Airbnb, etc.)"
    },
    "trip_members": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Copia de Trip.members en el momento de crear/sincronizar — usada por rls porque base44 no permite comprobar la pertenencia al viaje contra otra entidad. Se mantiene al día vía syncTripMembers() cada vez que cambia la membresía del viaje."
    }
  },
  "required": [
    "trip_id",
    "name"
  ],
  "rls": {
    "create": { "data.trip_members": { "$in": ["{{user.email}}"] } },
    "read": { "data.trip_members": { "$in": ["{{user.email}}"] } },
    "update": { "data.trip_members": { "$in": ["{{user.email}}"] } },
    "delete": { "data.trip_members": { "$in": ["{{user.email}}"] } }
  }
}