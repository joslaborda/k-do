{
  "name": "Spot",
  "type": "object",
  "properties": {
    "trip_id": {
      "type": "string",
      "description": "ID del viaje"
    },
    "city_id": {
      "type": "string",
      "description": "ID de la ciudad (opcional)"
    },
    "itinerary_day_id": {
      "type": "string",
      "description": "ID del d\u00eda de itinerario (opcional)"
    },
    "title": {
      "type": "string",
      "description": "Nombre del lugar"
    },
    "type": {
      "type": "string",
      // hotel/airport/train/bus se añadieron porque el buscador de spots
      // (resultados de OpenStreetMap, ver osmToType() en
      // src/components/spots/spotsHelpers.jsx) y el atajo "+ Añadir hotel"
      // ya generaban spots con estos valores — sin ellos en el enum, uno de
      // los flujos de creación más habituales de la app podía guardar un
      // spot con un type fuera del esquema declarado aquí.
      "enum": [
        "food",
        "sight",
        "activity",
        "shopping",
        "transport",
        "custom",
        "hotel",
        "airport",
        "train",
        "bus"
      ],
      "description": "Tipo de lugar"
    },
    "notes": {
      "type": "string",
      "description": "Notas adicionales"
    },
    "link": {
      "type": "string",
      "description": "Enlace externo (web, reserva, etc.)"
    },
    "address": {
      "type": "string",
      "description": "Direcci\u00f3n del lugar"
    },
    "lat": {
      "type": "number",
      "description": "Latitud (opcional)"
    },
    "lng": {
      "type": "number",
      "description": "Longitud (opcional)"
    },
    "created_by": {
      "type": "string",
      "description": "Email del creador"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "personal",
        "trip_members",
        "selected_users",
        "public"
      ],
      "default": "trip_members",
      "description": "Visibilidad del spot"
    },
    "shared_with": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Emails con acceso (solo si visibility=selected_users)"
    },
    "visited": {
      "type": "boolean",
      "default": false,
      "description": "\u00bfYa visitado?"
    },
    "visit_order": {
      "type": "number",
      "description": "Orden de visita (opcional)"
    },
    "created_by_user_id": {
      "type": "string",
      "description": "ID del usuario creador, para el perfil social"
    },
    "creator_username": {
      "type": "string",
      "description": "Username en el momento de crear"
    },
    "creator_avatar": {
      "type": "string",
      "description": "Avatar en el momento de crear"
    },
    "country": {
      "type": "string",
      "description": "Pa\u00eds del spot, para b\u00fasqueda"
    },
    "city_name": {
      "type": "string",
      "description": "Ciudad del spot, para b\u00fasqueda"
    },
    "assigned_date": {
      "type": "string",
      "format": "date",
      "description": "Fecha asignada del spot en el itinerario del viaje"
    },
    "assigned_time": {
      "type": "string",
      "description": "Hora asignada del spot (HH:MM)"
    },
    "day_order": {
      "type": "number",
      "description": "Orden del spot dentro del d\u00eda para el itinerario"
    },
    "saved_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Emails de usuarios que guardaron este spot (sin ser su creador) \u2014 usado por el filtro 'Guardados'"
    },
    "osm_id": {
      "type": "string",
      "description": "ID de OpenStreetMap si el spot vino de b\u00fasqueda OSM"
    },
    "source": {
      "type": "string",
      "enum": [
        "manual",
        "osm",
        "saved_import"
      ],
      "description": "C\u00f3mo se a\u00f1adi\u00f3 el spot: manual, importado de b\u00fasqueda OSM, o importado de la wishlist personal"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Etiquetas libres del spot \u2014 el campo faltaba en el schema y se perd\u00eda en cada creaci\u00f3n pese a tener UI completa (SpotsSection, SpotCard, etc.)"
    },
    "image_url": {
      "type": "string",
      "description": "Foto del spot \u2014 usada al importar desde SavedSpot (wishlist personal)"
    },
    "trip_members": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Copia de Trip.members en el momento de crear/sincronizar \u2014 usada por rls porque base44 no permite comprobar la pertenencia al viaje contra otra entidad. Se mantiene al d\u00eda v\u00eda syncTripMembers() cada vez que cambia la membres\u00eda del viaje."
    }
  },
  "required": [
    "trip_id",
    "title",
    "type"
  ],
  "rls": {
    "create": { "data.trip_members": { "$in": ["{{user.email}}"] } },
    "read": {
      "$or": [
        { "created_by": "{{user.email}}" },
        { "data.visibility": "public" },
        { "$and": [ { "data.visibility": "trip_members" }, { "data.trip_members": { "$in": ["{{user.email}}"] } } ] },
        { "$and": [ { "data.visibility": "selected_users" }, { "data.shared_with": { "$in": ["{{user.email}}"] } } ] }
      ]
    },
    "update": {
      "$or": [
        { "created_by": "{{user.email}}" },
        { "$and": [ { "data.visibility": "trip_members" }, { "data.trip_members": { "$in": ["{{user.email}}"] } } ] },
        { "$and": [ { "data.visibility": "selected_users" }, { "data.shared_with": { "$in": ["{{user.email}}"] } } ] }
      ]
    },
    "delete": {
      "$or": [
        { "created_by": "{{user.email}}" },
        { "$and": [ { "created_by": null }, { "data.trip_members": { "$in": ["{{user.email}}"] } } ] }
      ]
    }
  }
}